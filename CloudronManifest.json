  "tags": [
    "ai",
    "agent",
    "router",
    "gateway",
    "llm",
    "openai-compatible"
  ],
  "httpPort": 20128,
  "healthCheckPath": "/api/monitoring/health",
  "manifestVersion": 2,
  "minBoxVersion": "9.1.0",
  "memoryLimit": 524288000,
  "icon": "file://icon.png",
  "packagerName": "Robi",
  "packagerUrl": "https://github.com/vRobM",
  "addons": {
    "localstorage": {
      "sqlite": {
        "paths": ["/app/data/storage.sqlite"]
      }
    },
    "redis": {
      "noPassword": true
    },
    "oidc": {
      "loginRedirectUri": "/api/auth/oidc/callback",
      "logoutRedirectUri": "/",
      "tokenSignatureAlgorithm": "RS256"
    }
  },
  "postInstallMessage": "file://POSTINSTALL.md",
