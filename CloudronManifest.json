{
  "id": "com.toldyouso.omniroute",
  "title": "OmniRoute",
  "tagline": "Free AI gateway: one endpoint, 237+ providers, 90+ free",
  "description": "file://DESCRIPTION.md",
  "author": "diegosouzapw",
  "contactEmail": "vrobm@users.noreply.github.com",
